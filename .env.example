# CoinDCX API credentials — obtain from https://coindcx.com/api
COINDCX_API_KEY=your_api_key_here
COINDCX_SECRET=your_secret_here

# ── Capital settings ───────────────────────────────────────────────────────
# MARGIN_INR    : Total capital you are deploying on this bot (in INR).
#                 Set this to however much you are actually investing.
# FIXED_RISK_INR: Maximum you are willing to lose on a single trade.
#                 If not set, defaults to 5% of MARGIN_INR automatically.
#                 Example: MARGIN_INR=50000 and you risk 2% → FIXED_RISK_INR=1000
MARGIN_INR=10000
# FIXED_RISK_INR=500   # uncomment to override the 5% default

# USD/INR fallback rate — only used if CoinDCX USDT/INR ticker call fails.
# The bot fetches the live rate automatically; update this periodically as a safety net.
USD_INR_RATE=99.0

# ── Execution mode ─────────────────────────────────────────────────────────
# Run in paper-trading mode (no real orders). Set to false only after 14 days of simulation.
SIMULATION_MODE=true

# ── Database (optional — leave blank to use local SQLite) ──────────────────
# Sign up at https://turso.tech, create a DB, then fill these in.
# When set, both the bot (HuggingFace) and API (Render) share the same cloud DB.
# TURSO_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
